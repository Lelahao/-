{
  "name": "paizuo-assistant",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "electron/dist/main.js",
  "scripts": {
    "dev:backend": "python -m uvicorn server.main:app --host 127.0.0.1 --port 8765 --reload",
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "electron:compile": "tsc -p electron/tsconfig.json",
    "electron:dev": "npm run electron:compile && concurrently -k -n vite,electron \"npm run dev\" \"wait-on http://127.0.0.1:1420 && cross-env electron .\"",
    "build:desktop": "npm run build && npm run electron:compile && electron-builder"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@tauri-apps/api": "^2.9.1",
    "docx": "^9.6.1",
    "pptxgenjs": "^4.0.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.13.0",
    "xlsx": "^0.18.5",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.18",
    "@tauri-apps/cli": "^2.9.6",
    "@types/node": "^22.19.3",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.2",
    "concurrently": "^9.2.0",
    "cross-env": "^7.0.3",
    "electron": "^34.0.0",
    "electron-builder": "^25.1.8",
    "tailwindcss": "^4.1.18",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.paizuo.assistant",
    "productName": "paizuo-assistant",
    "directories": { "output": "release" },
    "files": ["dist/**/*", "electron/dist/**/*", "package.json"],
    "asar": true,
    "win": { "target": ["dir"], "signAndEditExecutable": false },
    "mac": { "target": ["dir"] },
    "linux": { "target": ["dir"] }
  }
}
